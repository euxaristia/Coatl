#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v realpath >/dev/null 2>&1; then
  SCRIPT_PATH="$(realpath "$SCRIPT_PATH")"
fi
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

SUBSET_FRONTEND="$ROOT_DIR/tools/coatl_subset_to_ir.sh"
IR_TO_X86_ASM="$ROOT_DIR/tools/ir_to_x86_64_asm.sh"
IR_TO_AARCH64_ASM="$ROOT_DIR/tools/ir_to_aarch64_asm.sh"
IR_TO_CBYTE="$ROOT_DIR/tools/ir_to_cbyte.sh"
CBYTE_VM="$ROOT_DIR/tools/cbyte_vm.sh"
X86_INTRINSICS="$ROOT_DIR/tests/intrinsics.s"
AARCH64_INTRINSICS="$ROOT_DIR/tests/intrinsics_aarch64.s"

usage() {
  cat <<'EOF'
usage:
  ./coatl [build] <input.coatl> [-o <output>] [--arch=x86_64|aarch64]
  ./coatl run-cbyte <input.cbyte>
  ./coatl --version

  "build" is optional — passing a .coatl file directly implies build.

  output type is inferred from -o extension:
    .s → asm    .ir → IR    .o → obj    .cbyte → Bytecode (VM)
    (no ext) → bin

  notes:
  - default arch is "auto" (auto-detects from uname -m)
EOF
}

print_version() {
  echo "coatl purified-native"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  --version|-V)
    print_version
    exit 0
    ;;
  --help|-h)
    usage
    exit 0
    ;;
esac

if [[ "$1" == *.coatl ]]; then
  cmd="build"
else
  cmd="$1"
  shift
fi

if [[ "$cmd" == "run-cbyte" ]]; then
  "$CBYTE_VM" "$1"
  exit 0
fi

if [[ "$cmd" != "build" ]]; then
  usage
  exit 1
fi

input="$1"
input_abs="$(realpath "$input")"
out="a.out"
arch="x86_64"
if [[ "$(uname -m)" == "aarch64" ]]; then arch="aarch64"; fi

shift
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o) out="$2"; shift 2 ;;
    --arch=*) arch="${1#--arch=}"; shift ;;
    *) shift ;;
  esac
done

emit="bin"
case "$out" in
  *.s) emit="asm" ;;
  *.ir) emit="ir" ;;
  *.o) emit="obj" ;;
  *.cbyte) emit="cbyte" ;;
  *) emit="bin" ;;
esac

out_abs="$(realpath -m "$out")"

assemble_asm_to_obj() {
  if [[ "$arch" == "aarch64" ]]; then
    as "$1" -o "$2"
  else
    as --64 "$1" -o "$2"
  fi
}

link_asm_to_bin() {
  if [[ "$arch" == "aarch64" ]]; then
    cc -fPIE -pie "$1" -o "$2"
  else
    cc -fPIE -pie "$1" -o "$2"
  fi
}

ir_pipeline_build_asm() {
  local tmp_ir="$(mktemp /tmp/coatl-ir.XXXXXX.ir)"
  local tmp_asm="$(mktemp /tmp/coatl-asm.XXXXXX.s)"
  local backend="$IR_TO_X86_ASM"
  if [[ "$arch" == "aarch64" ]]; then backend="$IR_TO_AARCH64_ASM"; fi

  "$SUBSET_FRONTEND" "$input_abs" -o "$tmp_ir"
  "$backend" "$tmp_ir" -o "$tmp_asm"
  
  if [[ "$arch" == "x86_64" ]]; then
    cat "$X86_INTRINSICS" >> "$tmp_asm"
  else
    cat "$AARCH64_INTRINSICS" >> "$tmp_asm"
  fi
  
  cp "$tmp_asm" "$out_abs"
  rm -f "$tmp_ir" "$tmp_asm"
}

if [[ "$emit" == "asm" ]]; then
  ir_pipeline_build_asm
elif [[ "$emit" == "bin" ]]; then
  tmp_asm="$(mktemp /tmp/coatl-bin.XXXXXX.s)"
  prev_out="$out_abs"
  out_abs="$tmp_asm"
  ir_pipeline_build_asm
  out_abs="$prev_out"
  link_asm_to_bin "$tmp_asm" "$out_abs"
  rm -f "$tmp_asm"
elif [[ "$emit" == "obj" ]]; then
  tmp_asm="$(mktemp /tmp/coatl-obj.XXXXXX.s)"
  prev_out="$out_abs"
  out_abs="$tmp_asm"
  ir_pipeline_build_asm
  out_abs="$prev_out"
  assemble_asm_to_obj "$tmp_asm" "$out_abs"
  rm -f "$tmp_asm"
elif [[ "$emit" == "ir" ]]; then
  "$SUBSET_FRONTEND" "$input_abs" -o "$out_abs"
elif [[ "$emit" == "cbyte" ]]; then
  local tmp_ir="$(mktemp /tmp/coatl-ir.XXXXXX.ir)"
  "$SUBSET_FRONTEND" "$input_abs" -o "$tmp_ir"
  "$IR_TO_CBYTE" "$tmp_ir" -o "$out_abs"
  rm -f "$tmp_ir"
fi
